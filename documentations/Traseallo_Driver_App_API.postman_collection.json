    {
      "name": "8. Ratings",
      "description": "Driver ratings and reviews.",
      "item": [
        {
          "name": "Get My Ratings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/drivers/{{driver_id}}/ratings",
              "host": ["{{base_url}}"],
              "path": ["drivers", "{{driver_id}}", "ratings"]
