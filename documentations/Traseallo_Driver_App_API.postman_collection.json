          }
        }
      ]
    },
    {
      "name": "9. Scanner",
      "description": "Barcode scanning for pickup confirmation and delivery.",
      "item": [
        {
          "name": "Scan Barcode",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scan_type\": \"pickup_scan\",\n  \"lat\": 25.2048,\n  \"lng\": 55.2708,\n  \"note\": \"Scanned at warehouse\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tracking/{{tracking_token}}/scan",
              "host": ["{{base_url}}"],
              "path": ["tracking", "{{tracking_token}}", "scan"]
            },
            "description": "Log barcode scan.\nscan_type values:\n- 'pickup_scan' → auto-transitions to picked_up\n- 'delivery_scan' → auto-transitions to delivered\n- 'driver_scan' → general scan log\n- 'warehouse_in' / 'warehouse_out'\n\nThe tracking_token is the barcode value."
          }
        },
        {
          "name": "Validate Pre-Generated Barcode",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tracking_token\": \"TRS-20260225-3365\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders/validate-pregenerated",
              "host": ["{{base_url}}"],
              "path": ["orders", "validate-pregenerated"]
            },
            "description": "Validate a pre-printed barcode token before using it."
          }
        },
        {
          "name": "Get Order by Tracking Token (Public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tracking/{{tracking_token}}",
              "host": ["{{base_url}}"],
              "path": ["tracking", "{{tracking_token}}"]
            },
            "description": "Public tracking endpoint. Returns order status, recipient info, driver info, status_logs."
          }
        }
      ]
    },
    {
      "name": "10. Pickups",
      "description": "Pickup workflow: view assigned pickups, confirm, arrive, fail.",
      "item": [
        {
          "name": "Get My Pickups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pickup/driver/my-pickups",
              "host": ["{{base_url}}"],
              "path": ["pickup", "driver", "my-pickups"]
            },
            "description": "All pickups assigned to this driver.\nReturns: order details, sender info, pickup_status, pickup_scheduled_at, client info."
          }
        },
        {
          "name": "Arrived at Pickup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lat\": 25.2048,\n  \"lng\": 55.2708\n}"
            },
            "url": {
              "raw": "{{base_url}}/pickup/{{order_id}}/arrived",
              "host": ["{{base_url}}"],
              "path": ["pickup", "{{order_id}}", "arrived"]
            },
            "description": "Mark arrival at pickup location."
          }
        },
        {
          "name": "Confirm Pickup Collected",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"barcode_scanned\": true,\n  \"notes\": \"Package collected\",\n  \"lat\": 25.2048,\n  \"lng\": 55.2708\n}"
            },
            "url": {
              "raw": "{{base_url}}/pickup/{{order_id}}/confirm",
              "host": ["{{base_url}}"],
              "path": ["pickup", "{{order_id}}", "confirm"]
            },
            "description": "Confirm pickup collected. Auto-advances order to 'picked_up' status."
          }
        },
        {
          "name": "Fail Pickup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Sender not available\",\n  \"lat\": 25.2048,\n  \"lng\": 55.2708\n}"
            },
            "url": {
              "raw": "{{base_url}}/pickup/{{order_id}}/fail",
              "host": ["{{base_url}}"],
              "path": ["pickup", "{{order_id}}", "fail"]
            },
            "description": "Mark pickup as failed with reason."
          }
        }
      ]
    },
