						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/driver-app/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"driver-app",
								"login"
							]
						},
						"description": "Authenticate driver using username, email, or phone.\n\nReturns JWT token, user info, driver profile, and tenant branding.\nThe token is automatically saved to the collection variable.",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"osama9557\",\n    \"password\": \"Driver@123\"\n}"
						},
						"auth": {
							"type": "noauth"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success && res.token) {",
									"    pm.collectionVariables.set('token', res.token);",
									"    pm.test('Login successful', () => pm.expect(res.success).to.be.true);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
