# Traseallo release signing — RENAME to keystore.properties and fill in.
# This file MUST be gitignored. Place the keystore OUTSIDE the repo
# (e.g. ~/.android-keystores/traseallo-release.keystore).
#
# Generate a release keystore (one-time):
#   keytool -genkeypair -v \
#     -keystore ~/.android-keystores/traseallo-release.keystore \
#     -alias traseallo-release -keyalg RSA -keysize 2048 -validity 10000
#
# Then duplicate this file as android/keystore.properties and edit:

TRASEALLO_RELEASE_STORE_FILE=/absolute/path/to/traseallo-release.keystore
TRASEALLO_RELEASE_STORE_PASSWORD=CHANGE_ME
TRASEALLO_RELEASE_KEY_ALIAS=traseallo-release
TRASEALLO_RELEASE_KEY_PASSWORD=CHANGE_ME
